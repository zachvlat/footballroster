{
  "name": "football-roster-builder",
  "version": "1.0.0",
  "description": "- **Project name**: Football Roster Builder\r - **Type**: Single-page web application (HTML/CSS/JS)\r - **Core functionality**: Create and manage football rosters by searching real players via API or adding custom players\r - **Target users**: Football enthusiasts, coaches, fantasy team builders",
  "main": "main.js",
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "football-roster-builder",
        "executableName": "football-roster-builder"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "football-roster-builder"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["win32"]
        }
      ]
    }
  },
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachvlat/football-roster-builder.git"
  },
  "keywords": [],
  "author": "Your Name",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/zachvlat/football-roster-builder/issues"
  },
  "homepage": "https://github.com/zachvlat/football-roster-builder#readme",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.football-roster-builder.app",
    "productName": "Football Roster",
    "files": [
      "index.html",
      "main.js"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
